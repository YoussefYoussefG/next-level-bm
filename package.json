  "description": "Next Level Node.js backend project: BM - Business Management Service. Enterprise-grade API with JWT auth, RBAC, transactional orders, analytics dashboard, and clean architecture.",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc",
