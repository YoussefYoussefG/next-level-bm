# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# ─── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/bm_db?schema=public"
PORT=3000
NODE_ENV=development

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-very-long-random-secret-key-at-least-32-chars"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Window duration in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window (global)
RATE_LIMIT_MAX=100
# Max auth attempts per window (login/register)
AUTH_RATE_LIMIT_MAX=10

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Allowed origins (use comma-separated for multiple, or '*' for all)
CORS_ORIGIN="*"
